{
  "name": "abs2kindle",
  "version": "0.2.1",
  "description": "Send ebooks from Audiobookshelf to your Kindle",
  "author": {
    "name": "TheSingularis",
    "email": "contact@abs2kindle.app"
  },
  "main": "src/main.js",
  "scripts": {
    "start": "/run/current-system/sw/bin/electron \"$PWD\"",
    "start:windows": "electron .",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.abs2kindle.app",
    "productName": "ABS2Kindle",
    "files": [
      "src/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm",
        "pacman"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
