{
  "name": "abs2kindle",
  "version": "1.0.0",
  "description": "Send ebooks from Audiobookshelf to your Kindle",
  "main": "src/main.js",
  "scripts": {
    "start": "/run/current-system/sw/bin/electron \"$PWD\"",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win"
  },
  "devDependencies": {
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.abs2kindle.app",
    "productName": "ABS2Kindle",
    "files": ["src/**/*"],
    "linux": {
      "target": ["AppImage", "deb"]
    },
    "win": {
      "target": ["nsis"]
    }
  }
}
